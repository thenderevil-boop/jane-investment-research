        "unreviewed",
        "reviewed",
        "rejected",
        "archived"
      ],
      "title": "Review Status",
      "type": "string"
    },
    "reviewed_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
