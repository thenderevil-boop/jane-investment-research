      "title": "Created By"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "evidence_quality_score": {
      "default": 0,
      "maximum": 100,
      "minimum": 0,
      "title": "Evidence Quality Score",
      "type": "integer"
    },
    "evidence_quality_label": {
