    },
    "source_reliability_label": {
      "default": "unknown",
      "enum": [
        "user_note",
        "official_company_material",
        "sec_filing_reference",
        "company_investor_relations",
        "reputable_third_party_research",
        "unknown",
        "other"
      ],
      "title": "Source Reliability Label",
      "type": "string"
    },
    "expires_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
