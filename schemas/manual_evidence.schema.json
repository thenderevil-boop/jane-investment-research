{
  "$defs": {
    "ManualEvidenceComparisonContext": {
      "properties": {
        "claimed_advantage": {
          "default": "unclear",
          "enum": [
            "stronger",
            "similar",
            "weaker",
            "unclear"
          ],
          "title": "Claimed Advantage",
          "type": "string"
        },
        "comparison_period": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Comparison Period"
        },
        "comparison_summary": {
          "minLength": 1,
          "title": "Comparison Summary",
          "type": "string"
        },
        "comparison_type": {
          "enum": [
            "competitor",
            "market_share",
            "product_capability",
            "platform_ecosystem",
            "customer_adoption",
            "pricing_power",
            "switching_cost",
            "r_and_d_intensity",
            "other"
          ],
          "title": "Comparison Type",
          "type": "string"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "metric_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Metric Name"
        },
        "metric_unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Metric Unit"
        },
        "metric_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Metric Value"
        },
        "peer_companies": {
          "items": {
            "type": "string"
          },
          "title": "Peer Companies",
          "type": "array"
        },
        "source_basis": {
          "default": "user_note",
          "enum": [
            "user_note",
            "company_filing",
            "investor_presentation",
            "third_party_research",
            "manual_estimate",
            "other"
          ],
          "title": "Source Basis",
          "type": "string"
        },
        "subject_company": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Subject Company"
        }
      },
      "required": [
        "comparison_type",
        "comparison_summary"
      ],
      "title": "ManualEvidenceComparisonContext",
      "type": "object"
    }
  },
  "properties": {
    "comparison_context": {
      "anyOf": [
        {
          "$ref": "#/$defs/ManualEvidenceComparisonContext"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "confidence": {
      "maximum": 1,
      "minimum": 0,
      "title": "Confidence",
      "type": "number"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "created_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": "local_user",
      "title": "Created By"
    },
    "criterion": {
      "enum": [
        "monopoly_power",
        "visionary_founder_ceo",
        "disruptive_innovation",
        "network_effect",
        "continuous_r_and_d",
        "mega_trend_fit"
      ],
      "title": "Criterion",
      "type": "string"
    },
    "evidence_id": {
      "title": "Evidence Id",
      "type": "string"
    },
    "evidence_quality_label": {
      "default": "incomplete",
      "enum": [
        "high",
        "medium",
        "low",
        "incomplete"
      ],
      "title": "Evidence Quality Label",
      "type": "string"
    },
    "evidence_quality_reasons": {
      "items": {
        "type": "string"
      },
      "title": "Evidence Quality Reasons",
      "type": "array"
    },
    "evidence_quality_score": {
      "default": 0,
      "maximum": 100,
      "minimum": 0,
      "title": "Evidence Quality Score",
      "type": "integer"
    },
    "evidence_type": {
      "enum": [
        "market_share",
        "patent",
        "platform_ecosystem",
        "founder_operator",
        "management_tenure",
        "product_disruption",
        "customer_adoption",
        "developer_ecosystem",
        "switching_cost",
        "brand_power",
        "r_and_d_intensity",
        "user_provided_note",
        "filing_reference",
        "competitor_comparison",
        "market_share_comparison",
        "product_capability_comparison",
        "ecosystem_comparison",
        "pricing_power_comparison",
        "switching_cost_comparison",
        "r_and_d_comparison",
        "other"
      ],
      "title": "Evidence Type",
      "type": "string"
    },
    "expires_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expires At"
    },
    "is_stale": {
      "default": false,
      "title": "Is Stale",
      "type": "boolean"
    },
    "last_reviewed_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Reviewed At"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "next_review_due_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Next Review Due At"
    },
    "review_notes": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Review Notes"
    },
    "review_status": {
      "default": "unreviewed",
      "enum": [
        "unreviewed",
        "reviewed",
        "rejected",
        "archived"
      ],
      "title": "Review Status",
      "type": "string"
    },
    "reviewed_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reviewed At"
    },
    "reviewed_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reviewed By"
    },
    "source_date": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Date"
    },
    "adr_evidence_type": {
      "anyOf": [
        {
          "enum": [
            "annual_report",
            "local_regulatory_filing",
            "governance_page",
            "investor_presentation",
            "earnings_webcast",
            "company_ir_page",
            "other"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "document_title": { "type": ["string", "null"], "default": null },
    "document_date": { "type": ["string", "null"], "default": null },
    "filing_period": { "type": ["string", "null"], "default": null },
    "quoted_text": { "type": ["string", "null"], "default": null },
    "local_market": { "type": ["string", "null"], "default": null },
    "local_ticker": { "type": ["string", "null"], "default": null },
    "translation_note": { "type": ["string", "null"], "default": null },
    "source_label": {
      "minLength": 1,
      "title": "Source Label",
      "type": "string"
    },
    "source_reliability_label": {
      "default": "unknown",
      "enum": [
        "user_note",
        "official_company_material",
        "sec_filing_reference",
        "company_investor_relations",
        "reputable_third_party_research",
        "unknown",
        "other"
      ],
      "title": "Source Reliability Label",
      "type": "string"
    },
    "source_url": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Url"
    },
    "stale_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Stale Reason"
    },
    "summary": {
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "ticker": {
      "maxLength": 10,
      "minLength": 1,
      "title": "Ticker",
      "type": "string"
    },
    "updated_at": {
      "title": "Updated At",
      "type": "string"
    },
    "user_provided": {
      "default": true,
      "title": "User Provided",
      "type": "boolean"
    }
  },
  "required": [
    "ticker",
    "criterion",
    "evidence_type",
    "summary",
    "source_label",
    "confidence"
  ],
  "title": "ManualQualitativeEvidence",
  "type": "object"
}