        "visionary_founder_ceo",
        "disruptive_innovation",
        "network_effect",
        "continuous_r_and_d",
        "mega_trend_fit"
      ],
      "title": "Criterion",
      "type": "string"
    },
    "evidence_type": {
      "enum": [
        "market_share",
        "patent",
        "platform_ecosystem",
        "founder_operator",
        "management_tenure",
        "product_disruption",
        "customer_adoption",
        "developer_ecosystem",
        "switching_cost",
        "brand_power",
        "r_and_d_intensity",
        "user_provided_note",
        "filing_reference",
        "other"
      ],
      "title": "Evidence Type",
      "type": "string"
    },
    "summary": {
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "source_label": {
      "minLength": 1,
      "title": "Source Label",
      "type": "string"
    },
    "source_url": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Url"
    },
    "source_date": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
