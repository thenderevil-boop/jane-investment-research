      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Stale Reason"
    },
    "evidence_id": {
      "title": "Evidence Id",
      "type": "string"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "updated_at": {
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "ticker",
    "criterion",
    "evidence_type",
    "summary",
    "source_label",
    "confidence"
  ],
  "title": "ManualQualitativeEvidence",
  "type": "object"
}