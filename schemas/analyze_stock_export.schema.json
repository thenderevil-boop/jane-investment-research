        {
          "type": "string"
        }
      ],
      "title": "Report"
    },
    "source_status": {
      "$ref": "#/$defs/DataSourceStatus"
    },
    "not_investment_advice": {
      "default": true,
      "title": "Not Investment Advice",
      "type": "boolean"
    }
