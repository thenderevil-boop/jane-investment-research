            "live",
            "cached_live",
            "mock",
            "fallback",
            "derived",
            "unknown"
          ],
          "title": "Source Type",
          "type": "string"
        },
        "provider": {
          "default": "unknown",
          "title": "Provider",
          "type": "string"
        },
        "source_date": {
          "default": "",
          "title": "Source Date",
          "type": "string"
        },
        "fetched_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fetched At"
        },
        "is_fresh": {
          "default": false,
          "title": "Is Fresh",
          "type": "boolean"
        },
        "freshness_window": {
          "default": "unknown",
          "title": "Freshness Window",
          "type": "string"
        },
        "fallback_used": {
          "default": false,
          "title": "Fallback Used",
          "type": "boolean"
        },
        "fallback_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fallback Reason"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "missing_data": {
          "items": {
            "type": "string"
          },
          "title": "Missing Data",
          "type": "array"
        }
      },
      "title": "DataSourceStatus",
      "type": "object"
    }
  },
  "properties": {
    "export_id": {
      "title": "Export Id",
      "type": "string"
    },
    "generated_at": {
      "title": "Generated At",
      "type": "string"
    },
    "ticker": {
      "title": "Ticker",
      "type": "string"
    },
    "format": {
      "enum": [
        "json",
        "markdown"
      ],
      "title": "Format",
      "type": "string"
    },
    "filename": {
      "title": "Filename",
      "type": "string"
    },
    "content_type": {
      "title": "Content Type",
      "type": "string"
    },
    "report": {
      "anyOf": [
        {
          "additionalProperties": true,
