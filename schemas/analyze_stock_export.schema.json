{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Analyze Stock Validation Export",
  "type": "object",
  "required": ["export_id", "generated_at", "ticker", "format", "filename", "content_type", "report", "source_status", "not_investment_advice"],
  "properties": {
    "export_id": {"type": "string"},
    "generated_at": {"type": "string"},
    "ticker": {"type": "string"},
    "format": {"enum": ["json", "markdown"]},
    "filename": {"type": "string", "pattern": "^jane-validation-[A-Z0-9_-]+-[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{6}Z\\.(json|md)$"},
    "content_type": {"enum": ["application/json", "text/markdown"]},
    "report": {
      "oneOf": [
        {
          "type": "object",
          "required": ["export_metadata", "validation_summary", "data_quality_summary", "evidence_matrix", "score_driver_breakdown", "next_manual_checks", "missing_data"],
          "properties": {
            "export_metadata": {
              "type": "object",
              "required": ["export_id", "generated_at", "format", "schema_version", "ticker", "market", "not_investment_advice", "limitations"],
              "properties": {
                "export_id": {"type": "string"},
                "generated_at": {"type": "string"},
                "format": {"const": "json"},
                "schema_version": {"const": "phase25_validation_export_v1"},
                "ticker": {"type": "string"},
                "market": {"const": "US"},
                "not_investment_advice": {"const": true},
                "limitations": {"type": "array", "items": {"type": "string"}}
              },
              "additionalProperties": false
            },
            "validation_summary": {
              "type": "object",
              "required": ["ticker", "score", "max_score", "label", "confidence", "data_quality_grade", "validation_summary", "primary_strengths", "primary_risks"],
              "properties": {
                "ticker": {"type": "string"},
                "score": {"type": ["number", "null"]},
                "max_score": {"type": ["number", "null"]},
                "label": {"type": ["string", "null"]},
                "confidence": {"type": ["number", "null"]},
                "data_quality_grade": {"type": ["string", "null"]},
                "validation_summary": {"type": ["string", "null"]},
                "primary_strengths": {"type": "array", "items": {"type": "string"}},
                "primary_risks": {"type": "array", "items": {"type": "string"}}
              },
              "additionalProperties": false
            },
            "data_quality_summary": {"type": ["object", "null"], "additionalProperties": true},
            "macro_context": {"type": ["object", "null"], "additionalProperties": true},
            "company_quality": {"type": ["object", "null"], "additionalProperties": true},
            "financial_statement_signals": {"type": ["object", "null"], "additionalProperties": true},
            "sec_financial_facts": {"type": ["object", "null"], "additionalProperties": true},
            "fundamentals_cross_check": {"type": ["object", "null"], "additionalProperties": true},
            "smart_money": {"type": ["object", "null"], "additionalProperties": true},
            "qualitative_evidence_assessment": {"type": ["object", "null"], "additionalProperties": true},
            "comparison_evidence_assessment": {"type": ["object", "null"], "additionalProperties": true},
            "evidence_matrix": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
            "score_driver_breakdown": {"type": ["object", "null"], "additionalProperties": true},
            "next_manual_checks": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
            "risk_flags": {"type": "array", "items": {"type": "string"}},
            "missing_data": {"type": "array", "items": {"type": "string"}},
            "source_limitations": {"type": "array", "items": {"type": "string"}},
            "raw_evidence": {"type": "object", "additionalProperties": true}
          },
          "additionalProperties": true
        },
        {"type": "string"}
      ]
    },
    "source_status": {
      "type": "object",
      "required": ["source_type", "provider", "freshness_window", "fallback_used"],
      "properties": {
        "source_type": {"const": "derived"},
        "provider": {"const": "analyze_stock_export"},
        "source_date": {"type": "string"},
        "fetched_at": {"type": ["string", "null"]},
        "is_fresh": {"type": "boolean"},
        "freshness_window": {"const": "export_generated_at"},
        "fallback_used": {"const": false},
        "fallback_reason": {"type": ["string", "null"]},
        "limitations": {"type": "array", "items": {"type": "string"}},
        "missing_data": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "not_investment_advice": {"const": true}
  },
  "additionalProperties": false
}
